{
  "name": "feedback-pipeline",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "description": "Slice 2 — Slack :mega: reaction -> Notion 'Customer Feedback' capture bot (Socket Mode).",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/core/*.test.ts src/backfill/*.test.ts src/adapters/**/*.test.ts",
    "setup:test-db": "tsx scripts/createTestDb.ts",
    "report": "tsx scripts/accuracyReport.ts",
    "correction-log": "tsx scripts/correctionLog.ts",
    "migrate:categories": "tsx scripts/migrateCategoriesToMultiSelect.ts",
    "digest": "tsx scripts/weeklyDigest.ts",
    "close-loop": "tsx scripts/closeLoop.ts",
    "eval:gate": "tsx scripts/runEval.ts gate",
    "eval:enricher": "tsx scripts/runEval.ts enricher",
    "eval:judge": "tsx scripts/runEval.ts judge",
    "eval:batch": "tsx scripts/runEval.ts --mode batch",
    "eval:thread": "tsx scripts/runEval.ts --mode thread",
    "eval:granola-gate": "tsx scripts/runEval.ts --mode granolaGate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.107.0",
    "@notionhq/client": "^2.2.15",
    "@slack/bolt": "^3.21.4",
    "@slack/web-api": "^6.12.1",
    "dotenv": "^16.4.7",
    "openai": "^6.46.0",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3"
  }
}
