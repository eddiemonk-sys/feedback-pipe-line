# --- Slack (Socket Mode) ---
# Bot User OAuth Token — from your Slack app's "OAuth & Permissions" page
SLACK_BOT_TOKEN=xoxb-your-bot-token
# App-Level Token with connections:write — from "Basic Information" > "App-Level Tokens"
SLACK_APP_TOKEN=xapp-your-app-token

# --- Capture sink: where captured feedback is written ---
# "notion" (default, production) or "file" (local test — writes to CAPTURES_FILE_PATH, no Notion token needed)
CAPTURE_SINK=notion
# Local capture file (only used when CAPTURE_SINK=file)
CAPTURES_FILE_PATH=./data/captures.jsonl

# --- Notion (only required when CAPTURE_SINK=notion) ---
# Internal integration secret — from https://www.notion.so/my-integrations
NOTION_API_KEY=ntn_your-notion-secret
# "Customer Feedback" database ID (already exists — DO NOT recreate it)
NOTION_DATABASE_ID=30f9ce0b212d403ab7b8e0a462f33cee

# --- Behaviour (optional; sensible defaults shown) ---
# Emoji name (without the colons) that triggers a capture
TRIGGER_EMOJI=mega
# Channel scope: membership-based — the bot captures in every channel it is invited to.
# To restrict access, simply do not invite the bot to channels you want excluded.
# Where the dedup log file lives (JSON)
DEDUP_STORE_PATH=./data/dedup.json

# --- AI Enrichment (optional) ---
# When set, each captured message is auto-summarised, categorised, and judged (confidence +
# rationale) before writing to Notion. Uses claude-haiku-4-5-20251001. Leave blank to disable.
ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI (only required when ENRICHER_MODEL, JUDGE_MODEL, or GATE_MODEL starts with "gpt-") ---
OPENAI_API_KEY=sk-...

# --- AI Vision (optional; requires ANTHROPIC_API_KEY and the Slack `files:read` scope) ---
# Comma-separated channel IDs where attached screenshots may be sent to Claude for description.
# SAFETY DEFAULT: leave blank to disable vision everywhere (fail closed). Screenshots can carry
# more incidental personal data than typed text — only add a channel here after confirming it's
# OK to send that channel's images to a third-party AI provider.
VISION_ENABLED_CHANNEL_IDS=

# --- Accuracy report (optional; run on-demand with `npm run report`) ---
# Reads human-reviewed rows (Category Reviewed / Summary Verdict) and writes an agreement-rate
# summary to a Notion page. Never changes bot behavior — read-only reporting.
# Leave blank on first run: the script creates the page and prints its ID for you to paste here,
# so future runs update the same page instead of creating a new one each time.
NOTION_REPORT_PAGE_ID=

# --- Related feedback detection (optional; uses ANTHROPIC_API_KEY) ---
# How many days back to check for a likely duplicate before creating a new row. Requires
# "Related Feedback" (relation), "Related Count" (rollup), and "Related Feedback Rationale"
# (text) to exist on the Notion DB first.
SIMILARITY_WINDOW_DAYS=30

# --- Distilled-rules guides (optional; appended to the enricher / similarity prompts) ---
# Human-curated principle files, loaded once at startup and added to the AI system prompts.
# Missing/empty = no change (fail-open). Committed in the repo; edit them in a distillation
# session (see DISTILLED-RULES-PRD.md). Defaults shown.
ENRICHMENT_STYLE_GUIDE_PATH=./docs/enrichment-style-guide.md
SIMILARITY_RULES_PATH=./docs/similarity-rules.md

# --- Backfill (optional; on-demand: `npx tsx scripts/backfillScan.ts` then `scripts/backfillCapture.ts`) ---
# Comma-separated Slack channel IDs the scan reads history from. The bot must be a MEMBER of each
# (public channels also need the channels:history scope). Empty = the scan errors (nothing to scan).
BACKFILL_CHANNEL_IDS=
# How many weeks of history to scan back.
BACKFILL_WEEKS_BACK=8
# A Notion page (shared with the bot's integration) the temporary Backfill Review DB is created under.
# Disposable staging — delete the DB + page once the backfill is captured into Customer Feedback.
BACKFILL_REVIEW_PARENT_PAGE_ID=
# Slack user id credited as "Flagged By" on backfilled captures (defaults to the bot).
BACKFILL_FLAGGED_BY_USER_ID=
